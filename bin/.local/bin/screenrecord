#!/usr/bin/env bash
# Toggle region recording (wf-recorder, VAAPI) -> ~/Videos.
set -euo pipefail

dir="$HOME/Videos"; mkdir -p "$dir"

if pgrep -x wf-recorder >/dev/null; then
    pkill -INT -x wf-recorder
    notify-send "Recording stopped" "Saved to ~/Videos"
else
    region=$(slurp) || exit 0
    file="$dir/rec-$(date +%Y%m%d-%H%M%S).mp4"
    wf-recorder -c h264_vaapi -d /dev/dri/renderD128 -g "$region" -f "$file" >/dev/null 2>&1 &
    notify-send "Recording started" "Region -> ~/Videos"
fi
