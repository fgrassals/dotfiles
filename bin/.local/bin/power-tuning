#!/usr/bin/env bash
# Power profiles + battery charge limit (fuzzel menu).
set -euo pipefail
prof=$(powerprofilesctl get 2>/dev/null || echo "?")
end=$(cat /sys/class/power_supply/BAT0/charge_control_end_threshold 2>/dev/null || echo 100)
mark() { [ "$1" = "$prof" ] && printf '  ÔùÅ'; }
if [ "${end:-100}" -le 80 ] 2>/dev/null; then c80='  ÔùÅ'; c100=''; else c80=''; c100='  ÔùÅ'; fi

chosen=$(printf '%s\n' \
  "´âº  Performance$(mark performance)" \
  "´ëÄ  Balanced$(mark balanced)" \
  "´ü¼  Power Saver$(mark power-saver)" \
  "´ëü  Limit to 80%$c80" \
  "´ëÇ  Charge to 100%$c100" \
  | fuzzel --dmenu --prompt 'power: ')

case "$chosen" in
  *Performance*)   powerprofilesctl set performance ;;
  *Balanced*)      powerprofilesctl set balanced ;;
  *"Power Saver"*) powerprofilesctl set power-saver ;;
  *"80%"*)  sudo set-charge-threshold 80;  notify-send "Battery" "Charge limit 80%" ;;
  *"100%"*) sudo set-charge-threshold 100; notify-send "Battery" "Charge to 100%" ;;
esac
