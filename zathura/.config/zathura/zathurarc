# Catppuccin Macchiato
set default-bg            "#24273a"
set default-fg            "#cad3f5"
set statusbar-bg         "#363a4f"
set statusbar-fg         "#cad3f5"
set inputbar-bg          "#24273a"
set inputbar-fg          "#cad3f5"
set notification-bg      "#24273a"
set notification-fg      "#cad3f5"
set notification-error-bg "#24273a"
set notification-error-fg "#ed8796"
set notification-warning-bg "#24273a"
set notification-warning-fg "#eed49f"
set highlight-color      "#eed49f"
set highlight-active-color "#8aadf4"
set completion-bg        "#363a4f"
set completion-fg        "#cad3f5"
set completion-highlight-bg "#8aadf4"
set completion-highlight-fg "#24273a"
set recolor-lightcolor   "#24273a"
set recolor-darkcolor    "#cad3f5"
set recolor              "false"
set recolor-keephue      "true"

# behaviour
set selection-clipboard  clipboard
set adjust-open          "best-fit"
set statusbar-home-tilde "true"
