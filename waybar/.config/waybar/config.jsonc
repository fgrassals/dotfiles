// -*- mode: jsonc -*-
{
  "layer": "top",
  "position": "top",
  "height": 26,
  "spacing": 0,
  "modules-left": [
    "hyprland/workspaces"
  ],
  "modules-center": [
    "hyprland/window",
    "clock"
  ],
  "modules-right": [
    "tray",
    "privacy",
    "custom/btop",
    "custom/nightlight",
    "idle_inhibitor",
    "bluetooth",
    "network",
    "pulseaudio",
    "battery",
    "custom/power"
  ],
  // =========================================================================
  // LEFT ‚Äî workspaces
  // =========================================================================
  "hyprland/workspaces": {
    "disable-scroll": true,
    "on-click": "activate",
    "show-special": false,
    "sort-by": "number",
    "format": "{id}",
    // Always show workspaces 1-5 regardless of whether they are open
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },
  // =========================================================================
  // CENTER ‚Äî window title + clock
  // Window title only shows when a window is focused.
  // When no window: clock sits centered alone, no dangling separator.
  // =========================================================================
  "hyprland/window": {
    "max-length": 50,
    "separate-outputs": true,
    // format is empty by default ‚Äî rewrite adds "| " only when title has content
    // This means: no window open ‚Üí module outputs nothing ‚Üí clock sits centered alone
    "format": "{title}",
    "rewrite": {
      "(.+) ‚Äî Mozilla Firefox": "$1",
      "(.+) - Brave": "$1",
      "(.+) - Google Chrome": "$1",
      // Catch-all: any other title gets the separator appended
      "(.+)": "$1 ‚Ä¢"
    }
  },
  "clock": {
    "format": " {:%H:%M}",
    // Click to toggle between time and full date
    "format-alt": " {:%A, %d %B %Y}",
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>"
  },
  // =========================================================================
  // RIGHT ‚Äî all modules always visible
  // =========================================================================
  "privacy": {
    "icon-spacing": 4,
    "icon-size": 14,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare"
      },
      {
        "type": "audio-in"
      }
    ]
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "Û∞í≥",
      "deactivated": "Û∞í≤"
    },
    "tooltip-format-activated": "Idle inhibitor ON ‚Äî screen will not sleep",
    "tooltip-format-deactivated": "Idle inhibitor OFF"
  },
  "tray": {
    "icon-size": 14,
    "spacing": 8
  },
  // Always visible: network, volume, battery, power
  "bluetooth": {
    "format": "Û∞ÇØ",
    "format-connected": "Û∞Ç±",
    "format-disabled": "Û∞Ç≤",
    "format-off": "Û∞Ç≤",
    "tooltip-format": "Bluetooth: {status}",
    "tooltip-format-connected": "{device_alias}",
    "tooltip-format-connected-battery": "{device_alias} ‚Äî {device_battery_percentage}%",
    "on-click": "foot --title bluetui bluetui"
  },
  // Always visible: network, volume, battery, power
  "network": {
    "format-wifi": "Û∞§®",
    "format-ethernet": "Û±òñ", // simple plug/ethernet icon
    "format-disconnected": "Û∞§≠",
    "format-linked": "Û∞§´",
    "tooltip-format-wifi": "{essid}  {signalStrength}%\n{ipaddr}",
    "tooltip-format-ethernet": "{ifname}  {ipaddr}/{cidr}",
    "tooltip-format-disconnected": "Disconnected",
    // Opens gazelle in a small floating foot window
    // Window rule in hyprland.conf matches title "gazelle"
    "on-click": "foot --title gazelle gazelle"
  },
  "pulseaudio": {
    "format": "{icon}",
    "format-muted": "Û∞ùü",
    "format-icons": {
      "headphone": "Û∞ãã",
      "headset": "Û∞ãé",
      "default": [
        "Û∞ïø",
        "Û∞ñÄ",
        "Û∞ïæ"
      ]
    },
    "tooltip-format": "{volume}% ‚Äî {desc}",
    // Opens wiremix in a small floating foot window
    // Window rule in hyprland.conf matches title "wiremix"
    "on-click": "foot --title wiremix wiremix",
    "scroll-step": 5
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    // On battery: icon only
    // Charging: plug icon + percentage (so you can track progress)
    // Plugged but full/not charging: plug icon only
    "format": "{icon}",
    "format-charging": "Û∞ÇÑ {capacity}%",
    "format-plugged": "Û∞ö•",
    "format-full": "Û∞Åπ",
    "format-icons": [
      "Û∞Å∫",
      "Û∞Åª",
      "Û∞Åº",
      "Û∞ÅΩ",
      "Û∞Åæ",
      "Û∞Åø",
      "Û∞ÇÄ",
      "Û∞ÇÅ",
      "Û∞ÇÇ",
      "Û∞Åπ"
    ],
    "tooltip-format": "{capacity}% ‚Äî {timeTo}\n{power}W",
    "on-click": "~/.local/bin/waybar-battery-threshold.sh"
  },
  "custom/btop": {
    "format": "Û∞çõ",
    "tooltip": true,
    "tooltip-format": "System monitor",
    "on-click": "sh -c 'pgrep -x btop || (foot -T btop -e btop &); hyprctl dispatch togglespecialworkspace btop'"
  },
  "custom/nightlight": {
    "format": "{}",
    "exec": "pgrep -x hyprsunset >/dev/null && echo 'Û∞ñî' || echo 'Û∞ñï'",
    "interval": 2,
    "tooltip-format": "Night light toggle",
    "on-click": "pgrep -x hyprsunset && killall hyprsunset || hyprsunset -t 3500"
  },
  "custom/power": {
    "format": "Û∞ê•",
    "tooltip": false,
    "on-click": "~/.local/bin/waybar-power-menu.sh"
  }
}
