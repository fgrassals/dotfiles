{
    "layer": "top",
    "position": "top",
    "height": 26,
    "spacing": 0,
    "modules-left": [
        "clock",
        "group/stats"
    ],
    "modules-center": [
        "niri/workspaces"
    ],
    "modules-right": [
        "group/status"
    ],
    "niri/workspaces": {
        "format": "{index}"
    },
    "niri/window": {
        "format": "{title}",
        "max-length": 50,
        "separate-outputs": true
    },
    "cpu": {
        "format": "َ°»  {usage}%",
        "interval": 2,
        "states": {
            "warning": 70,
            "critical": 90
        },
        "on-click": "kitty --class=floating-tui -e btop"
    },
    "memory": {
        "format": "َ°چ› {used:0.1f}G",
        "interval": 2,
        "states": {
            "warning": 80,
            "critical": 90
        },
        "on-click": "kitty --class=floating-tui -e btop"
    },
    "temperature": {
        "format": "َ°”ڈ {temperatureC}آ°C",
        "critical-threshold": 80
    },
    "privacy": {
        "icon-spacing": 4,
        "icon-size": 14,
        "transition-duration": 250,
        "modules": [
            {
                "type": "screenshare"
            },
            {
                "type": "audio-in"
            }
        ]
    },
    "custom/nightlight": {
        "exec": "~/.config/waybar/scripts/nightlight.sh status",
        "return-type": "json",
        "signal": 8,
        "on-click": "~/.config/waybar/scripts/nightlight.sh toggle",
        "tooltip": true
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "َ°’³",
            "deactivated": "َ°’²"
        },
        "tooltip-format-activated": "Idle inhibitor on â€” screen will not sleep",
        "tooltip-format-deactivated": "Idle inhibitor off"
    },
    "bluetooth": {
        "format": "َ°‚¯",
        "format-connected": "َ°‚±",
        "format-disabled": "َ°‚²",
        "format-off": "َ°‚²",
        "tooltip-format": "Bluetooth: {status}",
        "tooltip-format-connected": "{device_alias}",
        "on-click": "kitty --class=floating-tui -e bluetui"
    },
    "network": {
        "format-wifi": "َ°¤¨",
        "format-ethernet": "َ±ک–",
        "format-disconnected": "َ°¤­",
        "format-linked": "َ°¤«",
        "tooltip-format-wifi": "{essid}  {signalStrength}%\n{ipaddr}",
        "tooltip-format-ethernet": "{ifname}  {ipaddr}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "~/.config/waybar/scripts/network.sh"
    },
    "wireplumber": {
        "format": "{icon}",
        "format-muted": "َ°‌ں",
        "format-icons": [
            "َ°•؟",
            "َ°–€",
            "َ°•¾"
        ],
        "tooltip-format": "{volume}%  â€”  {node_name}",
        "on-click": "kitty --class=floating-tui -e wiremix",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}",
        "format-charging": "َ°‚„ {capacity}%",
        "format-plugged": "َ°ڑ¥",
        "format-full": "َ°پ¹",
        "format-icons": [
            "َ°پ؛",
            "َ°پ»",
            "َ°پ¼",
            "َ°پ½",
            "َ°پ¾",
            "َ°پ؟",
            "َ°‚€",
            "َ°‚پ",
            "َ°‚‚",
            "َ°پ¹"
        ],
        "tooltip-format": "{capacity}%  â€”  {timeTo}\n{power}W",
        "on-click": "~/.local/bin/power-tuning"
    },
    "tray": {
        "icon-size": 14,
        "spacing": 10
    },
    "custom/power": {
        "format": "َ°گ¥",
        "tooltip": false,
        "on-click": "~/.config/waybar/scripts/power.sh"
    },
    "clock": {
        "format": "َ°…گ {:%H:%M}",
        "format-alt": "َ°…گ {:%a %d %b}",
        "tooltip-format": "<big>{:%A, %d %B %Y}</big>\n<tt>{calendar}</tt>",
        "calendar": {
            "mode": "month"
        }
    },
    "group/stats": {
        "orientation": "horizontal",
        "modules": [
            "cpu",
            "memory",
            "temperature"
        ]
    },
    "group/status": {
        "orientation": "horizontal",
        "modules": [
            "tray",
            "privacy",
            "custom/nightlight",
            "idle_inhibitor",
            "bluetooth",
            "network",
            "wireplumber",
            "battery",
            "custom/power"
        ]
    }
}
